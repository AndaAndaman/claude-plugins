{
  "description": "Load dev-tools MCP tool instructions at session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/dev-tools_session-start.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
