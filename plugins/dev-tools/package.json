{
  "name": "dev-tools-mcp",
  "version": "0.2.0",
  "type": "module",
  "description": "AWS CLI tools exposed as MCP tools",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node20 --format=esm --minify --outfile=dist/devtool.server.js --sourcemap --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\""
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1007.0",
    "@aws-sdk/client-ecs": "^3.1006.0",
    "@aws-sdk/client-resource-groups-tagging-api": "^3.1006.0",
    "@aws-sdk/client-sts": "^3.1006.0",
    "@aws-sdk/credential-providers": "^3.1006.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}
